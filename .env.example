# Your delegated signer private key (NOT your Magic wallet private key)
PK=0xyour_private_key_here

# Your Magic wallet / Email wallet address (the funder address)
FUNDER=0xyour_magic_wallet_address_here

# Base bet amount in USDC (Martingale starting bet per coin)
ORDER_AMOUNT=2

# Maximum bet cap — Martingale will never exceed this per coin
MAX_BET=64

# Comma-separated coins to trade (BTC, ETH, SOL, XRP, DOGE — any combo)
COINS=BTC,ETH

# Which side to buy: Up or Down (Martingale only)
DIRECTION=Up

# Strategy to run: martingale | follower | both
# martingale — buys fixed direction at xx:00:10 with Martingale doubling on loss
# follower   — buys whichever token has higher price at xx:04:55 (market favourite)
# both       — runs both strategies each window
STRATEGY=martingale

# Follower strategy bet size in USDC (flat, no doubling)
FOLLOWER_BET=2

# Polygon RPC for Chainlink price feeds (default: public node)
# POLYGON_RPC=https://polygon-bor-rpc.publicnode.com

# Dashboard port (default 8080)
DASHBOARD_PORT=8080
